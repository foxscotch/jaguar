<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {% block head %}
      <title>{% block title %}Main{% endblock %} - Jaguar</title>
    {% endblock %}

    <link rel="stylesheet" href="{{ static('bootstrap/css/bootstrap.min.css') }}" />
    <link rel="stylesheet" href="{{ static('main/styles.css') }}" />
    <script defer src="{{ static('bootstrap/js/bootstrap.min.js') }}"></script>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="{{ reverse('main:index') }}">Jaguar</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" href="{{ reverse('fitness:index') }}">Fitness</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
    <div class="container pt-2">
      {% block content %}{% endblock %}
      <div id="footer">
        {% block footer %}{% endblock %}
      </div>
    </div>
  </body>
</html>
